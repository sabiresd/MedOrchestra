# Copiez ce fichier en .env et renseignez vos valeurs (ne jamais committer .env).

# --- MongoDB (Systeme d'Information Hospitalier) ---
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?appName=Cluster0
MONGODB_DB=sih_mcp_db

# --- Notification medecin (SMTP / passerelle e-mail -> SMS) ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USE_TLS=true
SMTP_USERNAME=votre.adresse@gmail.com
SMTP_PASSWORD=your_app_password
EMAIL_FROM=votre.adresse@gmail.com
EMAIL_TO=medecin.destinataire@example.com
